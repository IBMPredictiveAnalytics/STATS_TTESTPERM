msgstr "Test t di permutazione"

#: STATS_PERMTTEST.R:191
msgid "This procedure requires SPSS to be in Unicode mode"
msgstr "Questa procedura richiede che SPSS sia in modalità Unicode"

#: STATS_PERMTTEST.R:196
msgid "Variable specification is incorrect"
msgstr "La specifica della variabile è errata"

#: STATS_PERMTTEST.R:199
msgid "Case weights are ignored by this procedure"
msgstr "I pesi dei casi vengono ignorati da questa procedura"

#: STATS_PERMTTEST.R:203
msgid "Two variables are required for paired tests"
msgstr "Per i test abbinati sono necessarie due variabili"

#: STATS_PERMTTEST.R:206
msgid "The group variable is not used for paired tests and will be ignored"
msgstr ""
"La variabile di gruppo non viene utilizzata nei test abbinati e sarà "
"ignorata"

#: STATS_PERMTTEST.R:211
msgid "The group variable is required for this test"
msgstr "Per questo test è necessaria la variabile di gruppo"

#: STATS_PERMTTEST.R:214
msgid "Exactly two values must be supplied for the group specification"
msgstr ""
"Per la specifica di gruppo devono essere forniti esattamente due valori"

#: STATS_PERMTTEST.R:218
msgid "The group variable must have a nominal or ordinal measurement level."
msgstr ""
"La variabile di gruppo deve avere un livello di misurazione nominale o "
"ordinale."

#: STATS_PERMTTEST.R:230
#, c-format
msgid ""
"%s is not a valid variable name in R.  Please rename it to use this "
"procedure."
msgstr ""
"%s non è un nome di variabile valido in R.  Rinominare la variabile per "
"seguire questa procedura."

#: STATS_PERMTTEST.R:248
msgid "error fetching data"
msgstr "errore nel richiamo dei dati"

#: STATS_PERMTTEST.R:259
#, c-format
msgid ""
"There are no complete or eligible cases in the dataset or split number %s ."
"  Skipping"
msgstr ""
"Nel set di dati o nel numero di suddivisioni %s non ci sono casi completi o "
"idonei.  Ignorare"

#: STATS_PERMTTEST.R:264
#, c-format
msgid ""
"There are too few cases in a group in the dataset or split number %s.  "
"Skipping"
msgstr ""
"Nel set di dati o nel numero di suddivisioni %s il numero di casi in un "
"gruppo è insufficiente.  Ignorare"

