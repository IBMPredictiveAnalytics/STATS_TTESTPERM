msgstr "순열의 수"

#: STATS_PERMTTEST.R:375
msgid "Settings"
msgstr "설정"

#: STATS_PERMTTEST.R:376
msgid "Results computed by module MKinfer"
msgstr "MKinfer 모듈에 의해 산출된 결과"

#: STATS_PERMTTEST.R:384
msgid "t Test Settings"
msgstr "t-검정 설정"

#: STATS_PERMTTEST.R:392
msgid "Number of Cases"
msgstr "케이스 수"

#: STATS_PERMTTEST.R:393
msgid "t Statistic"
msgstr "t 통계량"

#: STATS_PERMTTEST.R:394
msgid "Degrees of Freedom"
msgstr "자유도"

#: STATS_PERMTTEST.R:395
msgid "P Value"
msgstr "P 값"

#: STATS_PERMTTEST.R:397
