msgstr "순열 추정 평균 차이"

#: STATS_PERMTTEST.R:407
msgid "Lower Permutation Confidence Interval"
msgstr "하위 순열 신뢰구간"

#: STATS_PERMTTEST.R:408
msgid "Upper Permutation Confidence Interval"
msgstr "상위 순열 신뢰구간"

#: STATS_PERMTTEST.R:409
msgid "Standardized Permutation Effect Size"
msgstr "표준화된 순열 효과 크기"

#: STATS_PERMTTEST.R:412
msgid "Statistics"
msgstr "통계"

#: STATS_PERMTTEST.R:415
msgid "Permutation t Tests"
msgstr "순열 t-검정"

