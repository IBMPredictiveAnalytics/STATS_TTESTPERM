#: STATS_PERMTTEST.R:94
msgid "End of procedure"
msgstr "Koniec procedury"

#: STATS_PERMTTEST.R:124
msgid "Message Number"
msgstr "Numer komunikatu"

#: STATS_PERMTTEST.R:159
#, c-format
msgid "Invalid variable name: %s"
msgstr "Niepoprawna nazwa zmiennej: %s"

#: STATS_PERMTTEST.R:166
msgid "Perm"
msgstr "Permutacja"

#: STATS_PERMTTEST.R:167
msgid "Perm t Test Notes and Warnings"
msgstr "Uwagi i ostrzeżenia dotyczące testu permutacji t"

#: STATS_PERMTTEST.R:188
msgid "Permutation t Test"
msgstr "Test permutacji t"

#: STATS_PERMTTEST.R:191
msgid "This procedure requires SPSS to be in Unicode mode"
msgstr "Ta procedura wymaga SPSS w trybie Unicode"

#: STATS_PERMTTEST.R:196
msgid "Variable specification is incorrect"
msgstr "Specyfikacja zmiennej nie jest poprawna"

#: STATS_PERMTTEST.R:199
msgid "Case weights are ignored by this procedure"
msgstr "Ta procedura ignoruje wagi przypadków"

#: STATS_PERMTTEST.R:203
msgid "Two variables are required for paired tests"
msgstr "Do testów sparowanych potrzebne są dwie zmienne"

#: STATS_PERMTTEST.R:206
msgid "The group variable is not used for paired tests and will be ignored"
msgstr ""
"Zmienna grupująca nie jest używana w testach sparowanych i zostanie "
"zignorowana"

#: STATS_PERMTTEST.R:211
msgid "The group variable is required for this test"
msgstr "Do przeprowadzenia tego testu wymagana jest zmienna grupująca"

#: STATS_PERMTTEST.R:214
msgid "Exactly two values must be supplied for the group specification"
msgstr "W specyfikacji grupy muszą zostać podane dokładnie dwie wartości"

#: STATS_PERMTTEST.R:218
msgid "The group variable must have a nominal or ordinal measurement level."
msgstr "Zmienna grupująca musi mieć poziom pomiaru nominalny lub porządkowy."

#: STATS_PERMTTEST.R:230
#, c-format
msgid ""
"%s is not a valid variable name in R.  Please rename it to use this "
"procedure."
msgstr ""
"%s nie jest poprawną nazwą zmiennej w języku R.  Zmień nazwę pliku, aby użyć"
" tej procedury."

#: STATS_PERMTTEST.R:248
msgid "error fetching data"
msgstr "błąd pobierania danych"

#: STATS_PERMTTEST.R:259
#, c-format
msgid ""
"There are no complete or eligible cases in the dataset or split number %s ."
"  Skipping"
msgstr ""
"Nie ma kompletnych ani kwalifikujących się przypadków w zbiorze danych lub "
"podziale o numerze %s.  Pominięcie"

#: STATS_PERMTTEST.R:264
#, c-format
msgid ""
"There are too few cases in a group in the dataset or split number %s.  "
"Skipping"
msgstr ""
"Jest zbyt mało przypadków w danej grupie w zbiorze danych lub podziale o "
"numerze %s.  Pominięcie"

#: STATS_PERMTTEST.R:290 STATS_PERMTTEST.R:293
msgid "error estimating equation"
msgstr "równanie szacowania błędu"

